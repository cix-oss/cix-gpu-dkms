 #
@@ -286,17 +287,17 @@ CFLAGS_MODULE += -Wno-ignored-qualifiers
 ifeq ($(CONFIG_GCOV_KERNEL),y)
     CFLAGS_MODULE += $(call cc-option, -ftest-coverage)
     CFLAGS_MODULE += $(call cc-option, -fprofile-arcs)
-    EXTRA_CFLAGS += -DGCOV_PROFILE=1
